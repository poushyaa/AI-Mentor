# ============================================================
# AI Code Mentor — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ============================================================

# --- AI / External APIs ---
# Get your free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# --- Flask Core ---
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# --- Security: Session Cookie ---
# Must be a long (>=32 char) random string. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# In development this is auto-generated per process if left empty.
# In production this MUST be set or the server will refuse to start.
SECRET_KEY=

# --- Security: CSRF Protection ---
# Another independent random string for CSRF tokens.
# Generate the same way as SECRET_KEY above.
WTF_CSRF_SECRET_KEY=

# --- Auth: JWT Secret ---
# Independent key used to sign JSON Web Tokens.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# --- Auth: Database ---
# Default: SQLite file in the instance/ folder (zero config, dev-only).
# Production: set to a PostgreSQL URL for persistence across restarts.
#   Example: DATABASE_URL=postgresql://user:pass@host:5432/ai_mentor
DATABASE_URL=sqlite:///app.db


# --- Security: CORS ---
# Comma-separated list of allowed frontend origins.
# NEVER use * in production — set your exact frontend URL.
# Examples:
#   Development:  ALLOWED_ORIGINS=http://localhost:5173
#   Production:   ALLOWED_ORIGINS=https://your-app.railway.app
ALLOWED_ORIGINS=http://localhost:5173

# --- Rate Limiting ---
# Use memory:// in development.
# Use redis://host:port in production for multi-worker support.
RATE_LIMIT_STORAGE_URI=memory://

# --- Frontend ---
# Set this if your React frontend talks to a different backend host.
# Leave empty when Flask serves the built frontend from /dist.
VITE_API_URL=

# --- Logging ---
LOG_LEVEL=INFO

# --- Proxy (Cloud deployments) ---
# Set to 1 on Railway / Render / Heroku for correct IP-based rate limiting.
TRUSTED_PROXY_COUNT=0

# --- Sandbox ---
# Set to 1 ONLY in local development if Docker is unavailable.
# NEVER set in production.
ALLOW_HOST_EXECUTION_FALLBACK=0
